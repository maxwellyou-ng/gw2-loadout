{
  "name": "gw2-loadout",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && npm run wiki:check && vite build",
    "lint": "eslint .",
    "check": "tsx scripts/engine-check.ts",
    "gen:icons": "tsx scripts/gen-icons.ts",
    "wiki:fetch": "tsx scripts/wiki-sync/snapshot.ts",
    "wiki:report": "tsx scripts/wiki-sync/report.ts",
    "wiki:fix": "tsx scripts/wiki-sync/fix.ts",
    "wiki:check": "tsx scripts/wiki-sync/check.ts",
    "wiki:test": "tsx scripts/wiki-sync/parse-recipe.test.ts",
    "wiki:audit": "tsx scripts/wiki-sync/audit-aliases.ts",
    "wiki:links": "tsx scripts/wiki-sync/check-links.ts",
    "preview": "vite preview",
    "predeploy": "VITE_BASE=/ npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
